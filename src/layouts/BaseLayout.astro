---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogUrl?: string;
  ogDescription?: string;
  keywords?: string;
  css?: string[];
  preloadImage?: string;
  showFooter?: boolean;
}

const {
  title,
  description = "Tiny Village Spirit works with organizations to build tiny home communities to shelter their unhoused neighbors.",
  ogTitle,
  ogUrl = "https://tinyvillagespirit.org",
  ogDescription,
  keywords = "Tiny Village Spirit, Tiny House Village, Tiny House, Tiny Home, Tiny House Village Construction, Tiny House Village Construction California, Tiny House Village Construction Bay Area, tiny homes, homeless shelter, tiny homes for homeless",
  css = [],
  preloadImage,
  showFooter = true,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="description" content={description}>
    <meta name="robots" content="index, follow" />
    <meta name="keywords" content={keywords}>
    <meta name="url" content={ogUrl}>
    <meta name="theme-color" content="#04747C">

    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content="https://tinyvillagespirit.org/media/logo-transparent.png" />
    <meta property="og:description" content={ogDescription || description} />

    {preloadImage && <link rel="preload" href={preloadImage} as="image">}

    <link rel="shortcut icon" href="/media/favicon.ico" type="image/png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" href="/styling/topnav.css">
    <link rel="stylesheet" href="/styling/footer.css">
    {css.map(href => <link rel="stylesheet" href={href} />)}
    <title>{title}</title>
</head>
<body>
    <Nav />
    <slot />
    {showFooter && <Footer />}
    <script is:inline src="/scripting/topnav.js"></script>
    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-VYD6FRZSK4"></script>
    <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-VYD6FRZSK4');
    </script>
</body>
</html>
