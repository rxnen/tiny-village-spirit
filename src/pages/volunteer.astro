---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Volunteer | Tiny Village Spirit"
  description="Sign up to volunteer with Tiny Village Spirit. Help build tiny home communities for unsheltered neighbors in the SF Bay Area — no experience needed."
  ogTitle="Volunteer | Tiny Village Spirit"
  ogUrl="https://tinyvillagespirit.org/volunteer"
  ogDescription="Sign up to volunteer with Tiny Village Spirit. Help build tiny home communities in the SF Bay Area — no experience needed."
  css={['/styling/volunteer.css']}
  preloadImage="/media/uli-image-2.jpeg"
>
<main>

    <!-- ============ HERO ============ -->
    <section class="vol-hero">
        <div class="vol-hero-grid">

            <!-- Left: copy -->
            <div class="vol-hero-copy">
                <div class="vol-eyebrow">Get involved</div>
                <h1 class="vol-hero-headline">
                    Come build<br>
                    <span class="vol-accent">with us.
                        <svg class="vol-swoop" viewBox="0 0 200 14" fill="none" aria-hidden="true">
                            <path d="M4 10 Q100 2 196 10" stroke="#07b1bd" stroke-width="3" stroke-linecap="round" fill="none"/>
                        </svg>
                    </span>
                </h1>
                <p class="vol-hero-sub">
                    No experience needed — just a willingness to show up. We build most Saturdays in Richmond, and every pair of hands makes a difference.
                </p>

                <div class="vol-hero-actions">
                    <a href="#vol-signup" class="vol-btn-primary">
                        <i class="fa fa-pencil"></i> Sign me up
                    </a>
                    <a href="https://www.facebook.com/groups/640023048324112/" target="_blank" rel="noopener" class="vol-btn-secondary">
                        <i class="fa fa-facebook"></i> Facebook group
                    </a>
                </div>
            </div>

            <!-- Right: photo collage -->
            <div class="vol-hero-media">
                <div class="vol-stamp" aria-hidden="true">
                    <span class="vol-stamp-top">every hand</span>
                    <span class="vol-stamp-mid">makes a<br>difference</span>
                    <span class="vol-stamp-bot">★ join us ★</span>
                </div>
                <div class="vol-photo-main">
                    <img src="/media/uli-image-2.jpeg" alt="Volunteers building at a Tiny Village Spirit build day" loading="eager">
                </div>
                <div class="vol-photo-stack">
                    <img src="/media/uli-image-4.jpeg" alt="Community members working together on a tiny home" loading="lazy">
                </div>
            </div>

        </div>
    </section>

    <!-- ============ WHY VOLUNTEER ============ -->
    <section class="vol-why">
        <div class="vol-why-grid">
            <div class="vol-why-card reveal">
                <div class="vol-why-icon"><i class="fa fa-wrench"></i></div>
                <h3>No skills required</h3>
                <p>We'll teach you everything on-site. From framing walls to painting murals — there's always a job for every kind of person.</p>
            </div>
            <div class="vol-why-card reveal">
                <div class="vol-why-icon"><i class="fa fa-users"></i></div>
                <h3>Build real community</h3>
                <p>Every Saturday is a mix of neighbors, students, faith groups, and first-timers — all working toward the same thing.</p>
            </div>
            <div class="vol-why-card reveal">
                <div class="vol-why-icon"><i class="fa fa-home"></i></div>
                <h3>See the impact directly</h3>
                <p>You'll watch a house go up board by board. When move-in day comes, you'll know you helped make it happen.</p>
            </div>
        </div>
    </section>

    <!-- ============ FORM SECTION ============ -->
    <section class="vol-form-section" id="vol-signup">
        <div class="vol-form-inner">

            <!-- Left info sidebar -->
            <div class="vol-form-info reveal">
                <div class="vol-info-eyebrow">Sign up</div>
                <h2>Ready to show up?</h2>
                <p>Fill out the form and we'll reach out with upcoming build days, advocacy events, and other ways to plug in.</p>

                <div class="vol-detail-list">
                    <div class="vol-detail-item">
                        <div class="vol-detail-icon"><i class="fa fa-map-marker"></i></div>
                        <div>
                            <div class="vol-detail-label">Location</div>
                            <div class="vol-detail-value">
                                <a href="https://maps.app.goo.gl/unMLnHvKZ5AGGk6U7" target="_blank">175 23rd St, Richmond, CA 94804</a>
                            </div>
                        </div>
                    </div>
                    <div class="vol-detail-item">
                        <div class="vol-detail-icon"><i class="fa fa-clock-o"></i></div>
                        <div>
                            <div class="vol-detail-label">Build day hours</div>
                            <div class="vol-detail-value">Open 9am – 4pm<br>Most Saturdays &amp; some Sundays</div>
                        </div>
                    </div>
                    <div class="vol-detail-item">
                        <div class="vol-detail-icon"><i class="fa fa-phone"></i></div>
                        <div>
                            <div class="vol-detail-label">Confirm before you come</div>
                            <div class="vol-detail-value"><a href="tel:5102820396">(510) 282-0396</a></div>
                        </div>
                    </div>
                    <div class="vol-detail-item">
                        <div class="vol-detail-icon"><i class="fa fa-facebook"></i></div>
                        <div>
                            <div class="vol-detail-label">Stay in the loop</div>
                            <div class="vol-detail-value">
                                <a href="https://www.facebook.com/groups/640023048324112/" target="_blank" rel="noopener">Richmond Project Facebook Group</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form card -->
            <div class="vol-form-card reveal">
                <h3>Volunteer sign-up</h3>
                <p>We'll be in touch shortly after you submit.</p>

                <form id="vol-form" novalidate>

                    <!-- Name + Email -->
                    <div class="vol-field-group">
                        <div class="vol-field">
                            <label class="vol-label" for="vol-name">Your name <span class="req">*</span></label>
                            <input class="vol-input" type="text" id="vol-name" name="entry.1499851839" placeholder="Jane Smith" required>
                        </div>
                        <div class="vol-field">
                            <label class="vol-label" for="vol-email">Email address <span class="req">*</span></label>
                            <input class="vol-input" type="email" id="vol-email" name="entry.900071446" placeholder="jane@example.com" required>
                        </div>
                    </div>

                    <!-- Phone -->
                    <div class="vol-field">
                        <label class="vol-label" for="vol-phone">Cell phone <span class="req">*</span></label>
                        <input class="vol-input" type="tel" id="vol-phone" name="entry.2122054439" placeholder="(510) 555-0123" required>
                    </div>

                    <div class="vol-form-divider"></div>

                    <!-- Weekend dates -->
                    <div class="vol-field">
                        <div class="vol-form-section-label">Which weekends work for you?</div>
                        <div class="vol-dates-grid">
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.255155046" value="Sat. Apr. 18">
                                Sat. Apr. 18
                            </label>
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.255155046" value="Sat. Apr. 25">
                                Sat. Apr. 25
                            </label>
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.255155046" value="Sun. May 3 -- Big special volunteer day!">
                                Sun. May 3 — <strong>Big day!</strong>
                            </label>
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.255155046" value="Sat. May 9">
                                Sat. May 9
                            </label>
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.255155046" value="Sat. May 16">
                                Sat. May 16
                            </label>
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.255155046" value="Sat. May 23">
                                Sat. May 23
                            </label>
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.255155046" value="Sun. May 31">
                                Sun. May 31
                            </label>
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.255155046" value="Sat. June 6">
                                Sat. June 6
                            </label>
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.255155046" value="Sat. June 13">
                                Sat. June 13
                            </label>
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.255155046" value="Sat. June 20">
                                Sat. June 20
                            </label>
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.255155046" value="Sat. June 27">
                                Sat. June 27
                            </label>
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.255155046" value="Sun. June 28">
                                Sun. June 28
                            </label>
                        </div>
                    </div>

                    <div class="vol-form-divider"></div>

                    <!-- Involvement type -->
                    <div class="vol-field">
                        <div class="vol-form-section-label">How would you like to get involved?</div>
                        <div class="vol-check-group">
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.1615768696" value="Individually Volunteer">
                                Individually Volunteer
                            </label>
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.1615768696" value="Organize a Group Volunteer Day (company, organization, friend group)">
                                Organize a Group Volunteer Day (company, org, friend group)
                            </label>
                            <label class="vol-check-label">
                                <input type="checkbox" name="entry.1615768696" value="Participate in Advocacy Opportunities (Petitions, Rallies, Community Organizing Events, etc)">
                                Participate in Advocacy Opportunities (petitions, rallies, organizing events)
                            </label>
                        </div>
                    </div>

                    <div class="vol-form-divider"></div>

                    <!-- Comments -->
                    <div class="vol-field">
                        <label class="vol-label" for="vol-comments">Questions or comments</label>
                        <textarea class="vol-textarea" id="vol-comments" name="entry.112512113" placeholder="Anything else you'd like us to know…"></textarea>
                    </div>

                    <button type="submit" class="vol-submit">
                        <i class="fa fa-check"></i> Sign me up
                    </button>
                </form>

                <!-- Success message -->
                <div class="vol-success" id="vol-success">
                    <div class="vol-success-icon"><i class="fa fa-check"></i></div>
                    <h3>You're in!</h3>
                    <p>Thanks for signing up. We'll reach out soon with upcoming build days and how to get involved.</p>
                </div>
            </div>

        </div>
    </section>

</main>
</BaseLayout>

<script is:inline>
// Scroll reveal
const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('in-view'); io.unobserve(e.target); }
    });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

// Form submission via fetch (no-cors to bypass CORS restriction)
document.getElementById('vol-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('.vol-submit');

    // Basic required field validation
    const name = form.querySelector('[name="entry.1499851839"]').value.trim();
    const email = form.querySelector('[name="entry.900071446"]').value.trim();
    const phone = form.querySelector('[name="entry.2122054439"]').value.trim();
    if (!name || !email || !phone) {
        [form.querySelector('[name="entry.1499851839"]'),
         form.querySelector('[name="entry.900071446"]'),
         form.querySelector('[name="entry.2122054439"]')].forEach(el => {
            if (!el.value.trim()) el.style.borderColor = '#e53e3e';
        });
        return;
    }

    btn.textContent = 'Sending…';
    btn.disabled = true;

    // Build form data
    const data = new FormData(form);

    try {
        await fetch(
            'https://docs.google.com/forms/d/e/1FAIpQLSecZghr5Mhw86wGWSfGoU5ToU33o7GU3KOykkkkoIrOxO4dzg/formResponse',
            { method: 'POST', body: data, mode: 'no-cors' }
        );
    } catch (_) {
        // no-cors always throws a TypeError on response read — that's expected
    }

    // Show success regardless (no-cors means we can't read response status)
    form.style.display = 'none';
    const success = document.getElementById('vol-success');
    success.style.display = 'flex';
});
</script>
