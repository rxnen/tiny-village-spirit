---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact | Tiny Village Spirit"
  description="Reach out to Tiny Village Spirit with questions, partnership ideas, or just to say hello."
  ogTitle="Contact | Tiny Village Spirit"
  ogUrl="https://tinyvillagespirit.org/contact"
  ogDescription="Reach out to Tiny Village Spirit with questions, partnership ideas, or just to say hello."
  css={['/styling/contact.css']}
>
<main>

    <!-- ============ HERO ============ -->
    <section class="con-hero">
        <div class="con-hero-inner">
            <h1 class="con-hero-title">
                We'd love to<br>
                <strong>hear from you.</strong>
            </h1>
            <p class="con-hero-sub">
                Questions, partnership ideas, media requests, or just want to say hello. We read every message.
            </p>
        </div>
    </section>

    <!-- ============ CONTACT DETAILS ============ -->
    <section class="con-details">
        <div class="con-details-inner">

            <a href="mailto:tinyvillagespirit@gmail.com" class="con-card">
                <div class="con-card-icon"><i class="fa fa-envelope-o"></i></div>
                <div class="con-card-label">Email</div>
                <div class="con-card-value">tinyvillagespirit@gmail.com</div>
            </a>

            <a href="tel:5102820396" class="con-card">
                <div class="con-card-icon"><i class="fa fa-phone"></i></div>
                <div class="con-card-label">Phone</div>
                <div class="con-card-value">(510) 282-0396</div>
            </a>

            <div class="con-card">
                <div class="con-card-icon"><i class="fa fa-map-marker"></i></div>
                <div class="con-card-label">Mailing address</div>
                <div class="con-card-value">
                    Attn. Sally Hindman<br>
                    Tiny Village Spirit<br>
                    3129 Ellis Street<br>
                    Berkeley, CA 94703
                </div>
            </div>

        </div>
    </section>

</main>
</BaseLayout>
