        <ul class="partners-list">
            <li>Berkeley High School Jewish Student Union</li>
            <li>B'nai B'rith Youth Organization (BBYO)</li>
            <li>Church of Jesus Christ Latter Day Saints</li>
            <li>Church of Santa Maria–Orinda</li>
            <li>College Park HS Jewish Student Union</li>
            <li>Congregation Beth El</li>
            <li>Contra Costa Midrasha</li>
            <li>First Congregational Church of Berkeley</li>
            <li>Impact Builder</li>
