---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Community Partners | Tiny Village Spirit"
  description="Learn more about Tiny Village Spirit's community partners and sponsors."
  ogTitle="Community Partners | Tiny Village Spirit"
  ogUrl="https://tinyvillagespirit.org/about/partners"
  ogDescription="Learn more about Tiny Village Spirit's community partners and sponsors."
  keywords="Tiny Village Spirit, Tiny House Village, Tiny House Community, Tiny House Village Partners, Tiny House Village Sponsors, Tiny House Village Donors, Tiny House Village Volunteers, Tiny House Village Community Organizing"
  css={['/styling/about/partners.css']}
  preloadImage="/media/partners-splash-1.jpg"
>
    <main>

        <div class="splash">
            <img src="/media/partners-splash-1.jpg" alt="About Image" class="splash-image" />
            <div class="splash-text">
                <h1>Community Partners</h1>
            </div>
        </div>

        <p class="partners-text">
            Tiny Village Spirit is grateful for the support of our community partners and sponsors.
            We are proud to work with these organizations to build a better future for our community.
        </p>

        <h1 class="category-header">Businesses</h1>
        <ul class="partners-list">
            <li>Arup</li>
            <li>Blue Shield</li>
            <li>Burchell Nursery</li>
