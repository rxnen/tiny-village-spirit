---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Richmond Tiny Village, Farm &amp; Garden | Tiny Village Spirit"
  description="A seven-agency collaboration doubling emergency housing for unsheltered youth in Richmond, CA. Volunteers building every week."
  ogTitle="Richmond Tiny Village, Farm &amp; Garden | Tiny Village Spirit"
  ogUrl="https://tinyvillagespirit.org/projects/richmond"
  ogDescription="A seven-agency collaboration doubling emergency housing for unsheltered youth in Richmond, CA. Volunteers building every week."
  keywords="Tiny Village Spirit, Tiny House Village, Richmond, CA, Richmond Tiny House Village, Richmond Tiny House Village Farm, Richmond Tiny House Village Garden"
  css={['/styling/projects/richmond.css']}
  preloadImage="/media/painted-house-1.jpg"
>
<main>

    <!-- ============ HERO ============ -->
    <section class="r-hero">
        <div class="r-hero-grid">
            <div class="r-hero-text">
                <div class="r-crumbs">
                    <a href="/">Home</a><span class="sep">/</span><a href="/projects">Projects</a><span class="sep">/</span>Richmond
                </div>
                <h1 class="r-title">
                    Richmond Tiny Village,<br>
                    <em>Farm &amp; Garden.</em>
                </h1>
                <p class="r-lede">
                    A seven‑agency collaboration to <strong style="color:#fff">double the emergency housing</strong> serving young people aged 18–24 in Richmond, CA — and pave the way for more tiny‑house villages across Contra Costa County.
                </p>

                <div class="r-hero-ctas">
                    <a href="https://www.gofundme.com/f/richmond-tiny-house-village-farm-and-garden" target="_blank" class="btn btn-yellow"><i class="fa fa-heart"></i> Donate to Richmond</a>
                    <a href="/volunteer" class="btn btn-outline-light">Volunteer on site <i class="fa fa-arrow-right"></i></a>
                </div>

                <div class="r-hero-stats">
                    <div>
                        <div class="r-hs-num">12 → 24</div>
                        <div class="r-hs-label">Emergency units</div>
                    </div>
                    <div>
                        <div class="r-hs-num">7</div>
                        <div class="r-hs-label">Partner agencies</div>
                    </div>
                    <div>
                        <div class="r-hs-num">Jul '26</div>
                        <div class="r-hs-label">Target move‑in</div>
                    </div>
                </div>
            </div>

            <div class="r-hero-photo">
                <div class="r-hero-photo-inner">
                    <img src="/media/painted-house-1.jpg" alt="Painted Richmond tiny home">
                </div>
                <div class="r-hero-tape">
                    <div class="small">175 23rd St</div>
                    <div class="big">Richmond, CA</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============ QUICK FACTS ============ -->
    <section class="r-facts">
        <div class="r-facts-inner">
            <div class="r-fact">
                <div class="r-fact-icon"><i class="fa fa-map-marker"></i></div>
                <div class="r-fact-label">Location</div>
                <div class="r-fact-value"><a href="https://maps.app.goo.gl/unMLnHvKZ5AGGk6U7" target="_blank">175 23rd St, Richmond, CA</a></div>
            </div>
            <div class="r-fact">
                <div class="r-fact-icon"><i class="fa fa-users"></i></div>
                <div class="r-fact-label">Who it serves</div>
                <div class="r-fact-value">Unsheltered youth, ages 18–24</div>
            </div>
            <div class="r-fact">
                <div class="r-fact-icon"><i class="fa fa-handshake-o"></i></div>
                <div class="r-fact-label">Collaboration</div>
                <div class="r-fact-value">7 partner agencies</div>
            </div>
            <div class="r-fact">
                <div class="r-fact-icon"><i class="fa fa-calendar"></i></div>
                <div class="r-fact-label">Target move‑in</div>
                <div class="r-fact-value">July 2026</div>
            </div>
        </div>
    </section>

    <!-- ============ ABOUT ============ -->
    <section class="r-about">
        <div class="r-about-grid">
            <div class="r-about-photo">
                <img src="/media/project-image-4.png" alt="Volunteers framing a tiny house">
            </div>
            <div class="r-about-text">
                <div class="section-eyebrow">About the project</div>
                <h2 class="section-headline" style="margin-bottom:24px;">Doubling emergency housing<br>for Richmond's youth.</h2>

                <p>Tiny Village Spirit is currently engaged in leading the creation of the <strong>Richmond Tiny House Village, Farm and Garden</strong> — a seven‑agency collaboration doubling the number of dedicated emergency housing units serving young people, ages 18 to 24, in Richmond, CA.</p>

                <p>We are increasing the number of emergency housing units serving Richmond youth from <strong>twelve to twenty‑four</strong>, and in doing so paving the way for more tiny house villages serving unsheltered people in Richmond and Contra Costa County.</p>

                <p>Volunteers are actively building on site every week.</p>

                <a href="/volunteer" class="btn btn-yellow" style="margin-top:8px;">
                    Learn more about how you can get involved <i class="fa fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </section>

    <!-- ============ TIMELINE ============ -->
    <section class="r-timeline">
        <div class="section-head">
            <div class="section-eyebrow center">Project timeline</div>
            <h2 class="section-headline center">From breaking ground to<br>opening the front door.</h2>
        </div>

        <div class="r-tl-track">
            <div class="r-tl-step done">
                <div class="r-tl-dot"></div>
                <div class="when">2023</div>
                <div class="what">Site secured</div>
            </div>
            <div class="r-tl-step done">
                <div class="r-tl-dot"></div>
                <div class="when">Early 2024</div>
                <div class="what">Permits &amp; design</div>
            </div>
            <div class="r-tl-step done">
                <div class="r-tl-dot"></div>
                <div class="when">Mid 2024</div>
                <div class="what">Groundbreaking</div>
            </div>
            <div class="r-tl-step done">
                <div class="r-tl-dot"></div>
                <div class="when">Late 2024</div>
                <div class="what">Framing &amp; painting</div>
            </div>
            <div class="r-tl-step now">
                <div class="r-tl-here">You are here</div>
                <div class="r-tl-dot"></div>
                <div class="when">Now</div>
                <div class="what">Interiors &amp; utilities</div>
            </div>
            <div class="r-tl-step todo">
                <div class="r-tl-dot"></div>
                <div class="when">July 2026</div>
                <div class="what">Move‑in day</div>
            </div>
        </div>
    </section>

    <!-- ============ GALLERY ============ -->
    <section class="r-gallery">
        <div class="section-head">
            <div class="section-eyebrow center">From the build site</div>
            <h2 class="section-headline center">A village raised<br>by many hands.</h2>
        </div>

        <div class="r-gallery-grid">
            <div class="r-gi r-gi-1"><img src="/media/painted-house-1.jpg" alt="Painted tiny house"></div>
            <div class="r-gi r-gi-2"><img src="/media/uli-image-4.jpeg" alt="Tiny home village under construction"></div>
            <div class="r-gi r-gi-3"><img src="/media/painted-house-2.jpg" alt="Volunteer mural fence"></div>
            <div class="r-gi r-gi-4"><img src="/media/uli-image-2.jpeg" alt="Volunteers digging on site"></div>
            <div class="r-gi r-gi-5"><img src="/media/uli-image-1.jpeg" alt="Volunteers painting rainbow planks"></div>
            <div class="r-gi r-gi-6"><img src="/media/uli-image-3.jpeg" alt="Volunteers painting boards on site"></div>
        </div>
    </section>

    <!-- ============ INVOLVE ============ -->
    <section class="r-involve">
        <div class="section-head">
            <div class="section-eyebrow center on-dark">Plug into Richmond</div>
            <h2 class="section-headline center" style="color:#fff;">Three ways to be part<br>of opening day.</h2>
        </div>

        <div class="r-involve-grid">
            <a href="https://www.gofundme.com/f/richmond-tiny-house-village-farm-and-garden" target="_blank" class="r-iv-card primary">
                <div class="r-iv-icon"><i class="fa fa-heart"></i></div>
                <h3>Donate to Richmond</h3>
                <p>$75 funds a wall panel. $500 funds a door. 100% goes into the village — no overhead.</p>
                <span class="r-iv-go">Give now →</span>
            </a>
            <a href="/volunteer" class="r-iv-card">
                <div class="r-iv-icon"><i class="fa fa-wrench"></i></div>
                <h3>Volunteer on site</h3>
                <p>Volunteers are actively building every week. Frame walls, paint murals, plant the garden.</p>
                <span class="r-iv-go">Sign up →</span>
            </a>
            <a href="https://www.facebook.com/groups/640023048324112/" target="_blank" rel="noopener" class="r-iv-card">
                <div class="r-iv-icon"><i class="fa fa-facebook"></i></div>
                <h3>Join the community</h3>
                <p>Build days, photo updates, and the occasional mural — straight from the Richmond Project Facebook group.</p>
                <span class="r-iv-go">Open Facebook →</span>
            </a>
        </div>
    </section>

    <!-- ============ VISIT ============ -->
    <section class="r-visit">
        <div class="r-visit-card">
            <div>
                <div class="section-eyebrow">Visit the village</div>
                <h2>Come see it being built.</h2>
                <address>
                    175 23rd Street<br>
                    Richmond, CA 94804<br><br>
                    <a href="https://maps.app.goo.gl/unMLnHvKZ5AGGk6U7" target="_blank">Open in Google Maps →</a>
                </address>
            </div>
            <a href="https://maps.app.goo.gl/unMLnHvKZ5AGGk6U7" target="_blank" class="r-visit-map">
                <div class="r-visit-pin"><i class="fa fa-map-marker"></i></div>
            </a>
        </div>
    </section>

</main>
</BaseLayout>

<script is:inline>
const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
        if (e.isIntersecting) {
            e.target.classList.add('in-view');
            io.unobserve(e.target);
        }
    });
}, { threshold: 0.12 });
document.querySelectorAll('.r-fact, .r-iv-card, .r-gi, .r-tl-step, .r-about-text, .r-about-photo, .r-hero-text, .r-hero-photo').forEach(el => {
    el.classList.add('reveal');
    io.observe(el);
});
</script>
